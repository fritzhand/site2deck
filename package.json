{
  "name": "site2deck",
  "version": "0.1.0",
  "description": "Turn any company website into a branded, offline, single-file HTML slide-deck builder: extract the site's design system, skin a shared deck engine with it, and iterate by eye.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://fritzhand.github.io/site2deck/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fritzhand/site2deck.git"
  },
  "bugs": {
    "url": "https://github.com/fritzhand/site2deck/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "extract": "node extract.mjs",
    "build": "node build.mjs",
    "serve": "python3 -m http.server 8000"
  },
  "keywords": [
    "slides",
    "presentation",
    "slideshow",
    "pitch-deck",
    "deck",
    "html-presentation",
    "design-tokens",
    "design-system",
    "brand",
    "branding",
    "scraper",
    "web-scraping",
    "single-file",
    "standalone-html",
    "offline-first",
    "zero-dependencies",
    "pdf-export",
    "css-custom-properties"
  ]
}
